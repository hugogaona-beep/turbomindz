# ─────────────────────────────────────────
# TURBOMINDZ — Environment Variables
# Copy to .env.local and fill in values
# ─────────────────────────────────────────

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=TURBOMINDZ

# ── Database (Supabase) ──────────────────
DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres
DIRECT_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT_ID].supabase.co:5432/postgres

# ── Supabase ─────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT_ID].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ── Auth ─────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=                          # openssl rand -base64 32

# ── Web3 / Alchemy ───────────────────────
NEXT_PUBLIC_ALCHEMY_ID=
ALCHEMY_API_KEY=
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=     # cloud.walletconnect.com
NEXT_PUBLIC_CHAIN_ID=1                    # 1=mainnet, 11155111=sepolia

# ── OpenSea ──────────────────────────────
OPENSEA_API_KEY=
NEXT_PUBLIC_OPENSEA_COLLECTION_SLUG=turbomindz

# ── Discord ──────────────────────────────
DISCORD_BOT_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_GUILD_ID=
DISCORD_VERIFIED_ROLE_ID=
DISCORD_REDIRECT_URI=http://localhost:3000/api/auth/callback/discord

# ── Pinata / IPFS ────────────────────────
PINATA_API_KEY=
PINATA_SECRET_KEY=
PINATA_JWT=
NEXT_PUBLIC_IPFS_GATEWAY=https://gateway.pinata.cloud/ipfs/

# ── Stripe ───────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── SendGrid ─────────────────────────────
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@turbomindz.com
SENDGRID_FROM_NAME=TURBOMINDZ

# ── Algolia ──────────────────────────────
NEXT_PUBLIC_ALGOLIA_APP_ID=
NEXT_PUBLIC_ALGOLIA_SEARCH_KEY=
ALGOLIA_ADMIN_KEY=
ALGOLIA_INDEX_NFTS=turbomindz_nfts
ALGOLIA_INDEX_LISTINGS=turbomindz_listings

# ── Upstash Redis ─────────────────────────
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Sentry ───────────────────────────────
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# ── Smart Contract ───────────────────────
NEXT_PUBLIC_CONTRACT_ADDRESS=0x...
NEXT_PUBLIC_NETWORK=mainnet
