# Normalize line endings for all text files
* text=auto eol=lf

# Force LF for source files
*.ts    text eol=lf
*.tsx   text eol=lf
*.js    text eol=lf
*.jsx   text eol=lf
*.json  text eol=lf
*.css   text eol=lf
*.md    text eol=lf
*.prisma text eol=lf
*.env*  text eol=lf

# Binary files — no conversion
*.png   binary
*.jpg   binary
*.jpeg  binary
*.gif   binary
*.webp  binary
*.ico   binary
*.pdf   binary
